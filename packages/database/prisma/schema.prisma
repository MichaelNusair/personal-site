generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transcription {
  id            String              @id @default(uuid()) @db.Uuid
  fileName      String              @map("file_name") @db.VarChar(500)
  fileKey       String              @map("file_key") @db.VarChar(500)
  fileSize      Int?                @map("file_size")
  duration      Int?
  status        TranscriptionStatus @default(PENDING)

  chunkDurationSec Int             @default(300) @map("chunk_duration_sec")
  totalChunks      Int?            @map("total_chunks")

  errorMessage  String?             @map("error_message") @db.Text

  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  completedAt   DateTime?           @map("completed_at") @db.Timestamptz

  chunks        TranscriptionChunk[]

  @@index([status])
  @@index([createdAt])
  @@map("transcriptions")
}

model TranscriptionChunk {
  id              String              @id @default(uuid()) @db.Uuid
  transcriptionId String              @map("transcription_id") @db.Uuid
  chunkIndex      Int                 @map("chunk_index")
  startTime       Float               @map("start_time")
  endTime         Float               @map("end_time")
  status          TranscriptionStatus @default(PENDING)

  segments          Json?
  correctedSegments Json?             @map("corrected_segments")

  errorMessage    String?             @map("error_message") @db.Text

  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  completedAt     DateTime?           @map("completed_at") @db.Timestamptz

  transcription   Transcription       @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)

  @@unique([transcriptionId, chunkIndex])
  @@index([transcriptionId])
  @@index([status])
  @@map("transcription_chunks")
}

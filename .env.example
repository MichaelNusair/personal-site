# ── White-label (optional; defaults to personal / michaelnusair.tech) ──
# NEXT_PUBLIC_SITE_PROFILE=personal
# NEXT_PUBLIC_SITE_URL=https://michaelnusair.tech
# NEXT_PUBLIC_CHAT_API_BASE=https://chatapi.michaelnusair.tech/
# Strike Labs build example:
# NEXT_PUBLIC_SITE_PROFILE=strike_labs
# NEXT_PUBLIC_SITE_URL=https://strikelabs.tech
# Optional GetVL funnel URLs (defaults to strike.getvl.shop paths)
# NEXT_PUBLIC_GETVL_START_IDEA_URL=https://strike.getvl.shop/start/idea
# NEXT_PUBLIC_GETVL_UPLOAD_RFQ_URL=https://strike.getvl.shop/start/upload

# NextAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://michaelnusair.tech

# Database
DATABASE_URL=postgresql://user:password@host:5432/transcriptions?schema=public

# AWS S3 (for audio file uploads)
UPLOADS_BUCKET=transcriptions-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure OpenAI (Whisper for transcription)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_WHISPER_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure OpenAI Realtime (for /realtime playground)
AZURE_OPENAI_REALTIME_API_KEY=
